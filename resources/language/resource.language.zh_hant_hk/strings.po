msgstr "使用者名稱或者密碼錯咗"

msgctxt "#33013"
msgid "Choose the audio stream"
msgstr "揀邊條聲軌"

msgctxt "#33014"
msgid "Choose the subtitles stream"
msgstr "揀邊條字幕"

msgctxt "#33015"
